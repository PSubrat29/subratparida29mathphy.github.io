        "title": "[Paper Title]",
        "authors": ["Your Name", "Co-author 1", "Co-author 2"],
        "venue": "[Journal/Conference Name]",
        "year": 2024,
        "type": "journal",
        "volume": "[optional]",
        "issue": "[optional]",
        "pages": "[optional]",
        "doi": "[DOI URL]",
        "pdfUrl": "[Link to PDF]",
        "codeUrl": "[Link to code repository - optional]",
        "bibtex": "[BibTeX citation - optional]"
      }
    ]
  },

  "experience": [
    {
      "position": "[Job Title]",
      "organization": "[Institution/Company]",
      "location": "[City, Country]",
      "startDate": "YYYY-MM",
      "endDate": "YYYY-MM or 'Present'",
      "description": "[Bullet points of responsibilities and achievements]"
    }
  ],

  "education": [
    {
      "degree": "[Degree Name, e.g., 'PhD in Computer Science']",
      "institution": "[University Name]",
      "location": "[City, Country]",
      "year": 2024,
      "thesisTitle": "[Thesis/Dissertation Title - optional]",
