    "methodologies": [
      "[Research Methods]",
      "[Analytical Techniques]"
    ],
    "languages": [
      {"language": "[Language]", "proficiency": "[Native/Fluent/Intermediate]"}
    ],
    "certifications": [
      "[Certification Name - optional]"
